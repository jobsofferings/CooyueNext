# ================================
# Git Webhook 自动部署服务 Dockerfile
# ================================
# 功能：接收 GitHub/GitLab webhook，自动触发 Docker 构建和部署
# 端口：9000 (可通过环境变量 WEBHOOK_PORT 修改)
# ================================

# ================================
# 基础镜像
# 使用 Alpine 版本以减小镜像体积
# ================================
FROM node:22.22.1-alpine AS base

# ================================
# 安装系统依赖
# - bash: 执行部署脚本
# - git: 拉取最新代码
# - docker-cli: 执行 docker build/push 等命令
# - docker-cli-compose: 执行 docker compose 命令
# ================================
RUN apk add --no-cache \
    bash \
    git \
    docker-cli \
    docker-cli-compose

# ================================
# 设置工作目录
# ================================
WORKDIR /app

# ================================
# 安装 Node.js 依赖
# 先复制 package.json 以利用 Docker 缓存层
# ================================
COPY package.json ./
RUN npm install --production

# ================================
# 复制应用文件
# ================================
COPY server.js ./

# 创建日志目录
RUN mkdir -p logs

# ================================
# 创建非 root 用户 (可选，但需要 docker.sock 权限)
# 注意：由于需要访问 docker.sock，通常以 root 运行
# ================================

# ================================
# 容器配置
# ================================
# 声明监听端口
EXPOSE 9000

# 设置环境变量默认值
ENV WEBHOOK_PORT=9000
ENV TARGET_BRANCH=main

# ================================
# 启动服务
# ================================
CMD ["node", "server.js"]
