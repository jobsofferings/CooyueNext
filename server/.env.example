# ──────────────────────────────────────────────
#  Products Database
# ──────────────────────────────────────────────
# The products_key database hosts: product_categories, products_key tables.
#
# Local dev: leave PRODUCTS_DATABASE_URL empty → uses PRODUCTS_PG_* vars below.
# Production / CI: set PRODUCTS_DATABASE_URL (overrides all PRODUCTS_PG_* vars).
PRODUCTS_DATABASE_URL=

PRODUCTS_PG_HOST=localhost
PRODUCTS_PG_PORT=5432
PRODUCTS_PG_DATABASE=products_key
PRODUCTS_PG_USER=postgres
PRODUCTS_PG_PASSWORD=postgres

# ──────────────────────────────────────────────
#  SEO Database
# ──────────────────────────────────────────────
# The seo_key database hosts: seo_keys, seo_records tables.
#
# Local dev: leave SEO_DATABASE_URL empty → uses SEO_PG_* vars below.
# Production / CI: set SEO_DATABASE_URL (overrides all SEO_PG_* vars).
SEO_DATABASE_URL=

SEO_PG_HOST=localhost
SEO_PG_PORT=5432
SEO_PG_DATABASE=seo_key
SEO_PG_USER=postgres
SEO_PG_PASSWORD=postgres

# ──────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────
PORT=3001

# ──────────────────────────────────────────────
#  SEO Webhook  (optional)
# ──────────────────────────────────────────────
SEO_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
#  Rate-limiting  (optional, defaults shown)
# ──────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# RATE_LIMIT_MAX=200             # max requests per window per IP
