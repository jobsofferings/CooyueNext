# ──────────────────────────────────────────────
#  Database
# ──────────────────────────────────────────────
# Local development: leave DATABASE_URL empty → uses individual PG_* vars below.
# Production / CI: set DATABASE_URL (connection string overrides all PG_* vars).
DATABASE_URL=

# Only used when DATABASE_URL is not set.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=cooyue
PG_USER=postgres
PG_PASSWORD=postgres

# ──────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────
PORT=3001

# ──────────────────────────────────────────────
#  SEO  (optional)
# ──────────────────────────────────────────────
# Key to sign CMS webhook payloads (optional – leave empty if no webhook is used)
SEO_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
#  Rate-limiting  (optional, defaults shown)
# ──────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# RATE_LIMIT_MAX=200             # max requests per window per IP
